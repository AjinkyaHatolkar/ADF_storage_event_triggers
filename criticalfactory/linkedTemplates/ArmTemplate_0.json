						"name": "Set variable1",
						"type": "SetVariable",
						"dependsOn": [
							{
								"activity": "get_file_name",
								"dependencyConditions": [
									"Succeeded"
								]
							}
						],
						"policy": {
							"secureOutput": false,
							"secureInput": false
						},
						"userProperties": [],
						"typeProperties": {
							"variableName": "value of filename",
							"value": {
								"value": "@activity('get_file_name').output.childItems[0].name",
